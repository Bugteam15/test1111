
<section class="relative overflow-hidden py-20">
  <!-- Background pattern - subtle grid for AI/tech feel -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%239C92FF\' fill-opacity=\'0.2\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
     background-size: 60px 60px;"></div>
  </div>
  
  <!-- Futuristic glowing orb effect -->
  <div class="absolute -top-40 -left-40 w-80 h-80 bg-rewards-purple/30 rounded-full filter blur-[100px]"></div>
  <div class="absolute -bottom-60 -right-40 w-96 h-96 bg-rewards-vibrantPurple/20 rounded-full filter blur-[120px]"></div>
  
  <div class="relative max-w-7xl mx-auto pt-16 pb-12 px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight animate-fade-in">
      <span class="block text-gradient">{{ section.settings.heading }}</span>
      <span class="block purple-gradient-text mt-2">{{ section.settings.subheading }}</span>
    </h1>
    <p class="mt-6 text-xl text-rewards-textMedium max-w-3xl animate-fade-in">
      {{ section.settings.description }}
    </p>
    <div class="mt-10 sm:flex justify-center gap-4 animate-fade-in">
      <a 
        href="{{ section.settings.primary_button_link }}" 
        class="w-full sm:w-auto flex items-center justify-center px-8 py-3 rounded-md text-white purple-gradient hover:opacity-90 md:py-4 md:text-lg md:px-10 transition-all duration-300 shadow-[0_0_15px_rgba(155,135,245,0.5)]"
      >
        {{ section.settings.primary_button_text }}
      </a>
      <a 
        href="{{ section.settings.secondary_button_link }}" 
        class="w-full sm:w-auto mt-4 sm:mt-0 flex items-center justify-center px-8 py-3 rounded-md text-white bg-white/10 border border-white/20 hover:bg-white/15 md:py-4 md:text-lg md:px-10 transition-all duration-300"
      >
        {{ section.settings.secondary_button_text }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Sweepstakes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "to Win Big!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Enter now for your chance to win amazing prizes like cash, gadgets, and more!"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Join Now"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
