
<section class="py-16 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-rewards-darkBlue/50"></div>
  <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-rewards-purple/20 rounded-full filter blur-[80px]"></div>
  <div class="absolute -top-40 -right-20 w-96 h-96 bg-rewards-vibrantPurple/10 rounded-full filter blur-[100px]"></div>
  
  <div class="container mx-auto px-4 text-center max-w-5xl relative z-10">
    <h2 class="text-3xl font-bold text-gradient">{{ section.settings.heading }}</h2>
    <p class="mt-4 text-lg text-rewards-textMedium max-w-2xl mx-auto">
      {{ section.settings.description }}
    </p>
    
    {% form 'customer' %}
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.input_placeholder }}"
          class="px-4 py-3 bg-white/10 border border-white/20 rounded-md focus:outline-none focus:ring-2 focus:ring-rewards-purple sm:w-64 w-full text-white placeholder-white/60"
          required
        />
        <button 
          type="submit"
          class="purple-gradient hover:opacity-90 text-white font-bold py-3 px-8 rounded-md transition-all duration-300 shadow-[0_0_15px_rgba(155,135,245,0.3)]"
        >
          {{ section.settings.button_text }}
        </button>
      </div>
    {% endform %}
    
    <p class="mt-4 text-sm text-rewards-textGray">
      {{ section.settings.footer_text }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "CTA Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Don't Miss Out!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Sign up today and start winning exclusive rewards. Join thousands of happy members already participating in our sweepstakes."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Sign Up Free"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "By signing up, you agree to our Terms of Service and Privacy Policy."
    }
  ],
  "presets": [
    {
      "name": "CTA Section",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
